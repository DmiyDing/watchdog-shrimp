{
  "name": "clawgate",
  "version": "0.1.1",
  "description": "clawgate: OpenClaw execution governance, approval gates, confirmation policy, and risk-based action boundaries.",
  "license": "Apache-2.0",
  "scripts": {
    "validate": "npm run validate:evals && npm run validate:consistency && npm run validate:activation",
    "validate:ci": "npm run validate:evals && npm run validate:consistency && npm run validate:activation:strict && npm run validate:workspace-sync:strict",
    "validate:evals": "node tooling/validate-evals.js",
    "validate:consistency": "node tooling/check-consistency.js",
    "validate:activation": "node tooling/check-activation.js --warn-only",
    "validate:activation:strict": "node tooling/check-activation.js",
    "validate:activation:semantic": "node tooling/check-activation.js --semantic",
    "validate:workspace-sync": "node tooling/check-workspace-sync.js --warn-only",
    "validate:workspace-sync:strict": "node tooling/check-workspace-sync.js",
    "validate:live": "node tooling/live-openclaw-check.js --mode safe",
    "validate:live:smoke": "node tooling/live-openclaw-check.js --mode safe",
    "validate:live:safe": "node tooling/live-openclaw-check.js --mode safe",
    "validate:live:mutating": "node tooling/live-openclaw-check.js --mode mutating",
    "validate:live:mutating:auth-token": "OPENCLAW_LIVE_DRY_RUN=1 node tooling/live-openclaw-check.js --mode auth-token",
    "validate:live:governance": "node tooling/live-openclaw-check.js --mode strict-governance",
    "validate:live:strict-governance": "node tooling/live-openclaw-check.js --mode strict-governance",
    "validate:ci:live": "node tooling/live-openclaw-check.js --mode safe"
  },
  "keywords": [
    "clawgate",
    "openclaw",
    "governance",
    "approval",
    "risk",
    "safety"
  ],
  "files": [
    "clawgate",
    "tooling",
    "acceptance",
    "README.md",
    "README.zh-CN.md",
    "RELEASE-CHECKLIST.md",
    "CHANGELOG.md"
  ]
}
